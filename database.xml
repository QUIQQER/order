<?xml version="1.0" encoding="UTF-8"?>
<database>
    <global>
        <table name="orders">
            <field type="bigint" autoincrement="true" primary="true">id</field>
            <field type="string" length="100" nullable="true" default="NULL">id_prefix</field>
            <field type="string" length="110" nullable="true" default="NULL">id_str</field>
            <field type="string" length="50" nullable="true" default="NULL">order_process_id</field>
            <field type="string" length="50" nullable="true" default="NULL">global_process_id</field>

            <!-- Für aufgesplittete Bestellungen -->
            <field type="bigint" nullable="true" default="NULL">parent_order</field>

            <!-- nur setzen wenn invoice gebucht ist -->
            <field type="string" length="50" nullable="true" default="NULL">invoice_id</field>
            <field type="string" length="50" nullable="true" default="NULL">temporary_invoice_id</field>
            <field type="integer">status</field>

            <field type="string" length="50" nullable="true" default="NULL">customerId</field>
            <field type="text" nullable="true">customer</field>
            <field type="text" nullable="true">addressInvoice</field>
            <field type="text" nullable="true">addressDelivery</field>

            <field type="text" nullable="true">articles</field>
            <field type="text" nullable="true">data</field>
            <field type="string" length="250" nullable="true">project_name</field>

            <field type="integer" nullable="true" default="NULL">payment_id</field>
            <field type="string" length="255" nullable="true" default="NULL">payment_method</field>
            <field type="text" nullable="true">payment_data</field> <!-- muss verschlüsselt sein -->
            <field type="datetime" nullable="true" default="NULL">payment_time</field>
            <field type="text" nullable="true">payment_address</field>
            <field type="integer">paid_status</field>
            <field type="integer" nullable="true">paid_date</field>
            <field type="text" nullable="true">paid_data</field>
            <field type="integer">successful</field>

            <field type="integer" nullable="true" default="NULL">shipping_id</field>
            <field type="text" nullable="true">shipping_data</field>
            <field type="integer" nullable="true" default="NULL">shipping_status</field>

            <field type="text" nullable="true">history</field>
            <field type="text" nullable="true">comments</field>
            <field type="text" nullable="true">custom_data</field>
            <field type="text" nullable="true" default="NULL">frontendMessages</field>
            <field type="text" nullable="true">status_mails</field>
            <field type="text" nullable="true">currency_data</field>
            <field type="string" length="10" nullable="true">currency</field>

            <field type="string" length="50">hash</field>
            <field type="timestamp" nullable="true" default="NULL">c_date</field>
            <field type="string" length="50">c_user</field>

            <index>invoice_id</index>
            <index>customerId</index>
            <index>customerId,c_date</index>
            <index>global_process_id</index>
            <index>hash</index>
        </table>

        <table name="orders_process">
            <field type="bigint" autoincrement="true" primary="true">id</field>
            <field type="string" length="100" nullable="true" default="NULL">id_prefix</field>
            <field type="string" length="110" nullable="true" default="NULL">id_str</field>
            <field type="string" length="50" nullable="true" default="NULL">order_id</field>

            <!-- Für aufgesplittete Bestellungen -->
            <field type="bigint" nullable="true" default="NULL">parent_order</field>
            <field type="string" length="50" nullable="true" default="NULL">invoice_id</field>
            <field type="string" length="50" nullable="true" default="NULL">temporary_invoice_id</field>
            <field type="integer">status</field>

            <field type="string" length="50" nullable="true" default="NULL">customerId</field>
            <field type="text" nullable="true">customer</field>
            <field type="text" nullable="true">addressInvoice</field>
            <field type="text" nullable="true">addressDelivery</field>

            <field type="text" nullable="true">articles</field>
            <field type="text" nullable="true">data</field>

            <field type="text" nullable="true">history</field>
            <field type="text" nullable="true">comments</field>
            <field type="text" nullable="true" default="NULL">frontendMessages</field>
            <field type="text" nullable="true">status_mails</field>
            <field type="text" nullable="true">currency_data</field>
            <field type="string" length="10" nullable="true">currency</field>

            <field type="integer" nullable="true" default="NULL">payment_id</field>
            <field type="string" length="255" nullable="true" default="NULL">payment_method</field>
            <field type="text" nullable="true">payment_data</field> <!-- muss verschlüsselt sein -->
            <field type="datetime" nullable="true" default="NULL">payment_time</field>
            <field type="text" nullable="true">payment_address</field>
            <field type="integer">paid_status</field>
            <field type="integer" nullable="true">paid_date</field>
            <field type="text" nullable="true">paid_data</field>
            <field type="integer">successful</field>

            <field type="integer" nullable="true" default="NULL">shipping_id</field>
            <field type="text" nullable="true">shipping_data</field>
            <field type="integer" nullable="true">shipping_status</field>

            <field type="string" length="50">hash</field>
            <field type="timestamp" nullable="true" default="NULL">c_date</field>
            <field type="string" length="50">c_user</field>

            <index>invoice_id</index>
            <index>customerId</index>
            <index>customerId,successful,c_date</index>
            <index>c_date</index>
            <index>hash</index>
        </table>

        <table name="baskets">
            <field type="bigint" autoincrement="true" primary="true">id</field>
            <field type="string" length="50">uid</field>
            <field type="bigint" nullable="true">name</field>
            <field type="text" nullable="true">products</field>
            <field type="string" length="50" nullable="true">hash</field>
            <field type="datetime" default="CURRENT_TIMESTAMP">e_date</field>

            <index>uid</index>
            <index>hash</index>
        </table>
    </global>
</database>
